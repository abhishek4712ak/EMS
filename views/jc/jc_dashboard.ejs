
<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('../superAdmin/base_styles.ejs') %>
  <title>JC Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      background: linear-gradient(135deg, #071229 60%, #06b6d4 100%);
      min-height: 100vh;
      margin: 0;
      font-family: 'Inter', sans-serif;
    }
    .navbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: #071229;
      padding: 1rem 2rem;
      color: white;
      box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }
    .navbar a {
      color: #06b6d4;
      text-decoration: none;
      font-weight: bold;
      margin-right: 1.5rem;
      transition: color 0.2s;
    }
    .navbar a:last-child {
      color: #fff;
      margin-right: 0;
      background: #06b6d4;
      padding: 0.5rem 1rem;
      border-radius: 6px;
      font-weight: 500;
      box-shadow: 0 1px 4px rgba(6,182,212,0.15);
    }
    .container {
      max-width: 600px;
      margin: 3rem auto;
      background: rgba(7,18,41,0.85);
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(6,182,212,0.12);
      padding: 2rem;
      color: #e6eef6;
      text-align: center;
    }
    h1 {
      font-size: 2.2rem;
      margin-bottom: 1rem;
      color: #06b6d4;
      letter-spacing: 1px;
    }
    p {
      font-size: 1.1rem;
      color: #e6eef6;
      margin-bottom: 2rem;
    }
    @media (max-width: 700px) {
      .container {
        margin: 1rem;
        padding: 1rem;
      }
      .navbar {
        flex-direction: column;
        align-items: flex-start;
        padding: 1rem;
      }
      h1 {
        font-size: 1.5rem;
      }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <div>
      <a href="/jc/dashboard">JC Dashboard</a>
    </div>
    <div>
      <a href="/jc/logout">Logout</a>
    </div>
  </nav>
  <div class="container">
    <h1>Welcome, <%= username %>!</h1>
    <p>Your dashboard is now responsive and visually enhanced for a better experience.</p>
    <img src="https://img.icons8.com/color/96/000000/student-center.png" alt="JC Icon" style="margin-bottom:1rem;" />
    <div style="margin-top:2rem;">
      <a href="/jc/events" style="background:#06b6d4;color:#fff;padding:0.7rem 1.5rem;border-radius:8px;text-decoration:none;font-weight:600;box-shadow:0 2px 8px rgba(6,182,212,0.15);transition:background 0.2s;">View Events</a>
    </div>
  </div>
</body>
</html>
