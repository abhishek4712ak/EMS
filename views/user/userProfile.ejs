<!DOCTYPE html>
<html lang="en">
<%- include('./userHeader.ejs') %>
<%- include('../superAdmin/base_styles.ejs') %>

<head>
  <title>User Profile</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">

  <style>
    /* General Styles */
    body {
      background: linear-gradient(120deg, #071229 60%, #06b6d4 100%);
      margin: 0;
      font-family: 'Inter', sans-serif;
      color: #e6eef6;
      min-height: 100vh;
    }

    /* Main container below header */
    main {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 4rem 1rem 2rem 1rem;
    }

    .container {
      width: 100%;
      max-width: 750px;
      background: rgba(255, 255, 255, 0.05);
      padding: 2.5rem;
      border-radius: 16px;
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.35);
      backdrop-filter: blur(14px);
      animation: fadeIn 1s ease;
    }

    h1 {
      margin: 0;
      font-size: 2.2rem;
      font-weight: 900;
      color: #06b6d4;
      letter-spacing: 1px;
      text-align: center;
    }

    .subtext {
      text-align: center;
      margin-top: 0.5rem;
      color: #94a3b8;
      font-size: 1rem;
      font-weight: 400;
    }

    .form-group {
      margin-top: 2rem;
      background: rgba(255,255,255,0.07);
      padding: 1.5rem;
      border-radius: 14px;
      box-shadow: inset 0 0 12px rgba(0,0,0,0.22);
    }

    .form-item {
      margin-bottom: 1.5rem;
    }

    .form-item label {
      display: block;
      color: #94a3b8;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    .form-item input,
    .form-item select {
      width: 100%;
      padding: 0.75rem;
      border: none;
      border-radius: 8px;
      background: rgba(255,255,255,0.1);
      color: #e6eef6;
      font-size: 1rem;
    }

    .form-item input::placeholder {
      color: #94a3b8;
    }

    .form-item select {
      background: rgba(255,255,255,0.1);
      color: #e6eef6;
    }

    .form-item select option {
      background: #071229;
      color: #e6eef6;
    }

    .submit-btn {
      width: 100%;
      padding: 1rem;
      background: #06b6d4;
      color: #071229;
      border: none;
      border-radius: 8px;
      font-size: 1.1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.3s ease;
    }

    .submit-btn:hover {
      background: #0891b2;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .container {
        padding: 1.8rem;
      }
      h1 {
        font-size: 1.8rem;
      }
      .form-item input,
      .form-item select {
        font-size: 0.95rem;
      }
    }

    /* Header Fix */
    header.user-header {
      position: sticky;
      top: 0;
      z-index: 1000;
    }
  </style>
</head>
<body>

  <!-- Main profile content -->
  <main>
    <div class="container">
      <% if (typeof error !== 'undefined' && error) { %>
        <div style="color: red; text-align: center; margin-bottom: 1rem;"><%= error %></div>
      <% } %>

      <% if (student) { %>
        <% if (isEdit) { %>
          <h1>Update Your Profile</h1>
          <p class="subtext">Fill in your details below. </p>

          <form action="/user/update-profile" method="POST" class="form-group">
            <div class="form-item">
              <label for="rollno">Roll Number</label>
              <input type="text" id="rollno" name="rollno" required placeholder="Enter your roll number" value="<%= student.rollno %>">
            </div>

            <div class="form-item">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Enter your full name" value="<%= student.name %>">
            </div>

            <div class="form-item">
              <label for="gender">Gender</label>
              <select id="gender" name="gender" required>
                <option value="">Select Gender</option>
                <option value="Male" <%= student.gender === 'Male' ? 'selected' : '' %>>Male</option>
                <option value="Female" <%= student.gender === 'Female' ? 'selected' : '' %>>Female</option>
                <option value="Other" <%= student.gender === 'Other' ? 'selected' : '' %>>Other</option>
              </select>
            </div>

            <div class="form-item">
              <label for="accommodation">Accommodation</label>
              <select id="accommodation" name="accommodation" required>
                <option value="">Select Accommodation</option>
                <option value="Yes" <%= student.accommodation === 'Yes' ? 'selected' : '' %>>Yes</option>
                <option value="No" <%= student.accommodation === 'No' ? 'selected' : '' %>>No</option>
              </select>
            </div>

            <div class="form-item">
              <label for="phone">Phone</label>
              <input type="tel" id="phone" name="phone" required placeholder="Enter your phone number" value="<%= student.phone %>">
            </div>

            <div class="form-item">
              <label for="address">Address</label>
              <input type="text" id="address" name="address" required placeholder="Enter your address" value="<%= student.address %>">
            </div>

            <div class="form-item">
              <label for="college">College</label>
              <input type="text" id="college" name="college" required placeholder="Enter your college name" value="<%= student.college %>">
            </div>

            <div class="form-item">
              <label for="branch">Branch</label>
              <input type="text" id="branch" name="branch" required placeholder="Enter your branch" value="<%= student.branch %>">
            </div>

            <div class="form-item">
              <label for="year">Year</label>
              <select id="year" name="year" required>
                <option value="">Select Year</option>
                <option value="1" <%= student.year == 1 ? 'selected' : '' %>>1st Year</option>
                <option value="2" <%= student.year == 2 ? 'selected' : '' %>>2nd Year</option>
                <option value="3" <%= student.year == 3 ? 'selected' : '' %>>3rd Year</option>
                <option value="4" <%= student.year == 4 ? 'selected' : '' %>>4th Year</option>
              </select>
            </div>

            <button type="submit" class="submit-btn">Update Profile</button>
          </form>
        <% } else { %>
          <h1>Your Profile</h1>
          <p class="subtext">Your profile information. </p>

          <div class="form-group">
            <div class="form-item">
              <label>PID</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.pid %></div>
            </div>

            <div class="form-item">
              <label>Email</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= email %></div>
            </div>

            <div class="form-item">
              <label>Roll Number</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.rollno %></div>
            </div>

            <div class="form-item">
              <label>Name</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.name %></div>
            </div>

            <div class="form-item">
              <label>Gender</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.gender %></div>
            </div>

            <div class="form-item">
              <label>Accommodation</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.accommodation %></div>
            </div>

            <div class="form-item">
              <label>Phone</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.phone %></div>
            </div>

            <div class="form-item">
              <label>Address</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.address %></div>
            </div>

            <div class="form-item">
              <label>College</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.college %></div>
            </div>

            <div class="form-item">
              <label>Branch</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.branch %></div>
            </div>

            <div class="form-item">
              <label>Year</label>
              <div style="padding: 0.75rem; background: rgba(255,255,255,0.1); color: #e6eef6; border-radius: 8px;"><%= student.year %>th Year</div>
            </div>

            <a href="/user/profile?edit=true" class="submit-btn" style="text-decoration: none; display: inline-block; text-align: center;">Update Profile</a>
          </div>
        <% } %>
      <% } else { %>
        <h1>Update Your Profile</h1>
        <p class="subtext">Fill in your details below. </p>

        <form action="/user/update-profile" method="POST" class="form-group">
          <div class="form-item">
            <label for="rollno">Roll Number</label>
            <input type="text" id="rollno" name="rollno" required placeholder="Enter your roll number">
          </div>

          <div class="form-item">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" required placeholder="Enter your full name">
          </div>

          <div class="form-item">
            <label for="gender">Gender</label>
            <select id="gender" name="gender" required>
              <option value="">Select Gender</option>
              <option value="Male">Male</option>
              <option value="Female">Female</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-item">
            <label for="accommodation">Accommodation</label>
            <select id="accommodation" name="accommodation" required>
              <option value="">Select Accommodation</option>
              <option value="Yes">Yes</option>
              <option value="No">No</option>
            </select>
          </div>

          <div class="form-item">
            <label for="phone">Phone</label>
            <input type="tel" id="phone" name="phone" required placeholder="Enter your phone number">
          </div>

          <div class="form-item">
            <label for="address">Address</label>
            <input type="text" id="address" name="address" required placeholder="Enter your address">
          </div>

          <div class="form-item">
            <label for="college">College</label>
            <input type="text" id="college" name="college" required placeholder="Enter your college name">
          </div>

          <div class="form-item">
            <label for="branch">Branch</label>
            <input type="text" id="branch" name="branch" required placeholder="Enter your branch">
          </div>

          <div class="form-item">
            <label for="year">Year</label>
            <select id="year" name="year" required>
              <option value="">Select Year</option>
              <option value="1">1st Year</option>
              <option value="2">2nd Year</option>
              <option value="3">3rd Year</option>
              <option value="4">4th Year</option>
            </select>
          </div>

          <button type="submit" class="submit-btn">Update Profile</button>
        </form>
      <% } %>
    </div>
  </main>

</body>
</html>
